# ═══════════════════════════════════════════════════════════════
# NexGate — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase (Server-side — used by simulator + engine)
FIREBASE_PROJECT_ID=nexgate-demo
FIREBASE_DATABASE_URL=https://nexgate-demo-default-rtdb.firebaseio.com
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Firebase (Client-side — used in dashboard/app.js inline config)
FIREBASE_API_KEY=your_web_api_key
FIREBASE_AUTH_DOMAIN=nexgate-demo.firebaseapp.com
FIREBASE_STORAGE_BUCKET=nexgate-demo.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Google Maps (optional — companion app only)
MAPS_API_KEY=your_maps_api_key

# Simulator
SIMULATION_SPEED=1
EVENT_TYPE=football_match
